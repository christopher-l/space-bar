{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "isolatedModules": true,
        "noEmit": false,
        "skipLibCheck": true,
        "paths": {
            "gnome-shell/*": ["./src/gnome-shell/*"],
            "@girs/gobject-2.0/*": ["./node_modules/@girs/gobject-2.0/*"],
            "@girs/glib-2.0/*": ["./node_modules/@girs/glib-2.0/*"],
            "@girs/gio-2.0/*": ["./node_modules/@girs/gio-2.0/*"],
            "@girs/gtk-4.0/*": ["./node_modules/@girs/gtk-4.0/*"],
            "@girs/adw-1/*": ["./node_modules/@girs/adw-1/*"],
            "@girs/gdk-4.0/*": ["./node_modules/@girs/gdk-4.0/*"],
            "@girs/clutter-17/*": ["./node_modules/@girs/clutter-17/*"],
            "@girs/st-17/*": ["./node_modules/@girs/st-17/*"],
            "@girs/meta-17/*": ["./node_modules/@girs/meta-17/*"],
            "@girs/shell-17/*": ["./node_modules/@girs/shell-17/*"],
            "@girs/gjs/*": ["./node_modules/@girs/gjs/*"]
        }
    }
}
