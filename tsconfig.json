{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "skipLibCheck": true,
        "target": "ES2023",
        "lib": ["ES2023"],
        "paths": {
            "types/*": ["./src/types/*"],
        },
    },
    "include": ["src/types/ambient.d.ts"],
    "files": ["src/prefs.ts", "src/extension.ts"],
}
